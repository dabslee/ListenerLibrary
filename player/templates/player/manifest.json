{% load static %}{
    "name": "ListenerLibrary",
    "short_name": "Listener",
    "description": "Your personal music and podcast library, playable offline.",
    "start_url": "/",
    "scope": "/",
    "display": "standalone",
    "orientation": "portrait",
    "background_color": "#212529",
    "theme_color": "#212529",
    "icons": [
        {
